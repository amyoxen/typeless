{
  "name": "voicecraft-dictation",
  "version": "0.1.0",
  "private": true,
  "description": "A Typeless-inspired AI voice dictation desktop app.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
